{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "freshrss",
  "title": "FreshRSS",
  "description": "Browse and manage FreshRSS feeds and articles from Raycast",
  "icon": "extension-icon.png",
  "author": "ebourgess",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "News"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "list-feeds",
      "title": "List Feeds",
      "description": "List all subscribed feeds",
      "mode": "view"
    },
    {
      "name": "add-feed",
      "title": "Add Feed",
      "description": "Subscribe to a new RSS/Atom feed",
      "mode": "view"
    },
    {
      "name": "remove-feed",
      "title": "Remove Feed",
      "description": "Unsubscribe from a feed",
      "mode": "view"
    },
    {
      "name": "unread-articles",
      "title": "Unread Articles",
      "description": "Browse unread articles",
      "mode": "view"
    },
    {
      "name": "read-articles",
      "title": "Read Articles",
      "description": "Browse read articles",
      "mode": "view"
    },
    {
      "name": "starred-articles",
      "title": "Starred Articles",
      "description": "Browse starred/favorite articles",
      "mode": "view"
    },
    {
      "name": "browse-categories",
      "title": "Browse by Category",
      "description": "Browse articles by category/label",
      "mode": "view"
    },
    {
      "name": "search-articles",
      "title": "Search Articles",
      "description": "Search articles across all feeds",
      "mode": "view"
    },
    {
      "name": "refresh-feeds",
      "title": "Refresh Feeds",
      "description": "Force refresh all feeds and clear cache",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "baseUrl",
      "title": "Base URL",
      "description": "Your FreshRSS instance URL (e.g. https://feed.ebourgess.dev)",
      "type": "textfield",
      "required": true,
      "default": "https://feed.ebourgess.dev",
      "placeholder": "https://feed.example.com"
    },
    {
      "name": "username",
      "title": "Username",
      "description": "Your FreshRSS username",
      "type": "textfield",
      "required": true,
      "placeholder": "alice"
    },
    {
      "name": "apiPassword",
      "title": "API Password",
      "description": "Your FreshRSS API password (not your login password)",
      "type": "password",
      "required": true,
      "placeholder": "Enter your API password"
    },
    {
      "name": "readwiseToken",
      "title": "Readwise Token",
      "description": "Your Readwise access token for saving articles to Reader (optional). Get yours at readwise.io/access_token",
      "type": "password",
      "required": false,
      "placeholder": "Enter your Readwise access token"
    },
    {
      "name": "autoMarkAsRead",
      "title": "Auto Mark as Read",
      "description": "Automatically mark articles as read when you open them",
      "type": "checkbox",
      "required": false,
      "default": false,
      "label": "Auto Mark as Read"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.0",
    "@raycast/utils": "^1.17.0"
  },
"devDependencies": {
    "@raycast/api": "^1.83.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "ray build",
    "build:beta": "ray build --target x",
    "dev": "ray develop",
    "dev:beta": "ray develop --target x",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
